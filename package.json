{
  "name": "doxie",
  "version": "0.1.0",
  "description": "Ship code and docs in one go — AI-driven documentation for your codebase.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "doxie": "src/cli.ts"
