    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^12.0.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^144.0.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
